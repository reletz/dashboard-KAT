# Salin ke /etc/kat-portal/api.env (chmod 600, owner kat-portal).
# Ini dibaca systemd (EnvironmentFile). JANGAN commit yang berisi nilai asli.

# Azure / Microsoft OAuth — sama dengan yang dipakai frontend.
TENANT_ID=<GUID-tenant-ITB>
CLIENT_ID=<client-id-app-registration>

# BOOTSTRAP ring 1: admin pertama supaya bisa login & isi tabel users via panel
# "Kelola Panitia". Setelah itu, role dikelola dari DB (tabel users), bukan di sini.
RING1_EMAILS=ketua@mahasiswa.itb.ac.id,wakil@mahasiswa.itb.ac.id

PORT=8787
DB_PATH=/var/lib/kat-portal/portal.db

# WAJIB false di production.
AUTH_DEV_BYPASS=false
