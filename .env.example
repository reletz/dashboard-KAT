# Frontend env. Isi dari Azure Portal → App Registration.
# Kalau kosong → portal jalan DEMO MODE (login dummy + API mock in-memory).
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=

# Paksa demo mode meski Azure terisi (opsional, untuk preview): true / false
VITE_DEMO_MODE=

# Catatan: backend punya env terpisah → lihat server/.env.example & deploy/api.env.example
