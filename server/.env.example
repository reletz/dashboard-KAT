# ── Azure / Microsoft OAuth ──────────────────────────────────────────────
# Tenant ITB (GUID) — sama dengan VITE_AZURE_TENANT_ID di frontend.
TENANT_ID=
# Client ID app registration — sama dengan VITE_AZURE_CLIENT_ID di frontend.
# Backend memverifikasi id_token punya aud == CLIENT_ID ini.
CLIENT_ID=

# ── Role / akses ─────────────────────────────────────────────────────────
# BOOTSTRAP: email di sini selalu dianggap ring 1 walau belum ada di tabel users,
# supaya admin pertama bisa login lalu mendaftarkan panitia lain lewat panel
# "Kelola Panitia". Setelah tabel users terisi, DB jadi sumber kebenaran.
# (Akses STRICT: yang tidak ada di users & bukan bootstrap → tidak bisa masuk.)
RING1_EMAILS=ketua@mahasiswa.itb.ac.id,wakil@mahasiswa.itb.ac.id

# ── Runtime ──────────────────────────────────────────────────────────────
PORT=8787
# Lokasi file SQLite. Di server production: /var/lib/kat-portal/portal.db
DB_PATH=./data/portal.db

# ── Dev only ─────────────────────────────────────────────────────────────
# true → request tanpa Authorization header diperlakukan sebagai ring-1.
# JANGAN PERNAH true di production.
AUTH_DEV_BYPASS=false
